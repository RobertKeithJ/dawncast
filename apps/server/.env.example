# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Get this from your Supabase project dashboard: Settings > Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# URL of the deployed frontend (used for CORS allow-list)
# Local dev: http://localhost:3001
# Production: https://your-app.vercel.app (or your custom domain)
CORS_ORIGIN=http://localhost:3001

# ── Optional ─────────────────────────────────────────────────────────────────
# Environment (development | production | test). Defaults to "development".
NODE_ENV=development

# Only needed to run: bun run seed:quotes
# Not required for the running server.
# GEMINI_API_KEY=your-gemini-api-key-here
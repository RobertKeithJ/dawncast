{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "seed:quotes": "bun run scripts/classify-quotes.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@google/generative-ai": "^0.24.1",
    "@project-dailyquotes/db": "workspace:*",
    "@project-dailyquotes/env": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "papaparse": "^5.5.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@project-dailyquotes/config": "workspace:*",
    "@types/bun": "^1.0.0",
    "@types/papaparse": "^5.5.2",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
